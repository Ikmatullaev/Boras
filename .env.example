# Environment file template for Boras Docker deployment
#
# Copy to .env and fill in your credentials:
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.

# ─── Camera credentials (REQUIRED) ─────────────────────────────────────────
CRANE_CAMERA_IP=10.0.0.1
CRANE_CAMERA_USER=admin
CRANE_CAMERA_PASS=your-camera-password

# ─── Web panel auth (REQUIRED) ─────────────────────────────────────────────
# Password for HTTP Basic Auth (login: admin by default)
CRANE_API_TOKEN=your-long-random-web-panel-password

# ─── Telegram notifications (REQUIRED for alerts + bot) ────────────────────
# Get token from @BotFather, get chat_id from getUpdates API
CRANE_TELEGRAM_TOKEN=
CRANE_TELEGRAM_CHAT_ID=
# Auto-enables when both token and chat_id are set
# CRANE_NOTIFICATIONS_ENABLED=true

# ─── Telegram bot (Part B — interactive control from Telegram) ─────────────
# Enable interactive bot (PTZ control, live-stream, settings menu, WebApp).
# Requires aiogram in requirements.txt. Set to false to disable bot but keep
# outbound notifications (target_detected alerts).
CRANE_BOT_ENABLED=true
# Password required when a new user sends /start to the bot. After successful
# auth, their chat_id is added to authorized_chats in SQLite.
CRANE_BOT_PASSWORD=your-bot-access-password
# Comma-separated list of pre-authorized Telegram chat IDs that get boss role
# without entering the password. Get your chat_id by messaging the bot then
# visiting https://api.telegram.org/bot<TOKEN>/getUpdates
# Example: CRANE_AUTHORIZED_CHAT_IDS=123456789,987654321
CRANE_AUTHORIZED_CHAT_IDS=
# Role assigned to new users after password auth: boss / guard / viewer
# boss = full access (settings + PTZ + live + manage users)
# guard = PTZ + live + AI toggle (no settings, no user management)
# viewer = live + notifications only (no PTZ control)
CRANE_DEFAULT_ROLE=viewer
# Public base URL of your Boras instance — used for "Access to camera" buttons
# in Telegram notifications and WebApp links. Example: https://boras.example.com
CRANE_PUBLIC_BASE_URL=
# URL of WebApp mini-app (served by Boras at /webapp). Telegram opens this
# inside its iframe. Usually same as public_base_url + "/webapp".
# Example: https://boras.example.com/webapp
CRANE_WEBAPP_URL=
# Interval (seconds) between live-stream frames sent to Telegram chats
CRANE_LIVE_STREAM_INTERVAL=2.0
# Redis URL for multi-instance bot state. Leave empty for single-instance
# (uses SQLite instead). Example: redis://localhost:6379/0
CRANE_REDIS_URL=

# ─── Multi-camera identification ───────────────────────────────────────────
# Unique ID for this camera. In multi-camera setups, each Boras instance has
# its own camera_id. Used in notifications and Telegram callbacks.
CRANE_CAMERA_ID=default
# Human-readable name shown in notifications and bot menus
CRANE_CAMERA_NAME=360 camera

# ─── Tuning (OPTIONAL) ─────────────────────────────────────────────────────
# CRANE_YOLO_MODEL=yolov8n.pt
# CRANE_FRAME_SKIP_RATE=3
# CRANE_AUTH_USERNAME=admin
# CRANE_PTZ_PROFILE=PROFILE_000
# CRANE_MIN_COMMAND_INTERVAL=0.15
# CRANE_PAN_SPEED_GAIN=0.5
# Bug 3 fix: default timeout is now 5s (was 10s). Override here if needed.
# CRANE_MANUAL_OVERRIDE_TIMEOUT=5
# Bug 2 fix: return camera to home position (pan=0, tilt=0) after manual
# override timeout expires. Set to 0 to disable.
# CRANE_RETURN_TO_HOME_AFTER_MANUAL=1
# Bug 2 fix: also reset zoom to 1x when returning home.
# CRANE_ZOOM_RESET_ON_HOME=1
# Bug 2 fix: seconds to wait after goto_home() before re-enabling AI.
# CRANE_HOME_SETTLE_DELAY=2.0
# CRANE_DISABLE_FOCUS=1
